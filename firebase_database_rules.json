{
  "rules": {
    "users": {
      "$userId": {
        "profile": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId"
        },
        "crops": {
          "$cropId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && auth.uid == $userId",
            "live": {
              ".read": true,
              ".write": true
            },
            "alerts": {
              ".read": "auth != null && auth.uid == $userId",
              ".write": true
            },
            "history": {
              ".read": "auth != null && auth.uid == $userId",
              ".write": true
            }
          }
        }
      }
    },
    "deviceStatus": {
      ".read": true,
      ".write": true
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    }
  }
}