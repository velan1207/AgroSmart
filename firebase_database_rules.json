{
  "rules": {
    "users": {
      "$userId": {
        ".read": true,
        ".write": true,
        "field": {
          "history": {
            ".indexOn": ["timestamp"]
          }
        }
      }
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    }
  }
}